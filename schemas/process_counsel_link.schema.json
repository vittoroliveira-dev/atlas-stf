{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/process_counsel_link.schema.json",
  "title": "ProcessCounselLink",
  "description": "Relação canônica entre processo e advogado ou representante.",
  "type": "object",
  "additionalProperties": false,
  "required": ["link_id", "process_id", "counsel_id", "source_id"],
  "properties": {
    "link_id": {"type": "string"},
    "process_id": {"type": "string"},
    "counsel_id": {"type": "string"},
    "side_in_case": {"type": ["string", "null"]},
    "source_id": {"type": "string"},
    "created_at": {"type": ["string", "null"], "format": "date-time"},
    "updated_at": {"type": ["string", "null"], "format": "date-time"}
  }
}
