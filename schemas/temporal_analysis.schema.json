{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/temporal_analysis.schema.json",
  "title": "TemporalAnalysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_kind",
    "record_id",
    "decision_count",
    "favorable_count",
    "unfavorable_count",
    "generated_at"
  ],
  "properties": {
    "analysis_kind": {"type": "string", "enum": ["monthly_minister", "yoy_process_class", "seasonality", "event_window", "corporate_link_timeline"]},
    "record_id": {"type": "string"},
    "rapporteur": {"type": ["string", "null"]},
    "decision_month": {"type": ["string", "null"]},
    "decision_year": {"type": ["integer", "null"]},
    "month_of_year": {"type": ["integer", "null"], "minimum": 1, "maximum": 12},
    "process_class": {"type": ["string", "null"]},
    "decision_count": {"type": "integer", "minimum": 0},
    "favorable_count": {"type": "integer", "minimum": 0},
    "unfavorable_count": {"type": "integer", "minimum": 0},
    "favorable_rate": {"type": ["number", "null"]},
    "rolling_favorable_rate_6m": {"type": ["number", "null"]},
    "breakpoint_score": {"type": ["number", "null"]},
    "breakpoint_flag": {"type": ["boolean", "null"]},
    "current_favorable_rate": {"type": ["number", "null"]},
    "prior_decision_count": {"type": ["integer", "null"], "minimum": 0},
    "prior_favorable_rate": {"type": ["number", "null"]},
    "delta_vs_prior_year": {"type": ["number", "null"]},
    "delta_vs_overall": {"type": ["number", "null"]},
    "event_id": {"type": ["string", "null"]},
    "event_type": {"type": ["string", "null"]},
    "event_scope": {"type": ["string", "null"]},
    "event_date": {"type": ["string", "null"], "format": "date"},
    "event_title": {"type": ["string", "null"]},
    "source": {"type": ["string", "null"]},
    "source_url": {"type": ["string", "null"]},
    "status": {"type": ["string", "null"]},
    "before_decision_count": {"type": ["integer", "null"], "minimum": 0},
    "before_favorable_rate": {"type": ["number", "null"]},
    "after_decision_count": {"type": ["integer", "null"], "minimum": 0},
    "after_favorable_rate": {"type": ["number", "null"]},
    "delta_before_after": {"type": ["number", "null"]},
    "linked_entity_type": {"type": ["string", "null"]},
    "linked_entity_id": {"type": ["string", "null"]},
    "linked_entity_name": {"type": ["string", "null"]},
    "company_cnpj_basico": {"type": ["string", "null"]},
    "company_name": {"type": ["string", "null"]},
    "link_degree": {"type": ["integer", "null"], "minimum": 1},
    "link_chain": {"type": ["string", "null"]},
    "link_start_date": {"type": ["string", "null"], "format": "date"},
    "link_status": {"type": ["string", "null"]},
    "establishment_count": {"type": ["integer", "null"], "minimum": 0},
    "active_establishment_count": {"type": ["integer", "null"], "minimum": 0},
    "headquarters_uf": {"type": ["string", "null"]},
    "headquarters_cnae_label": {"type": ["string", "null"]},
    "economic_group_id": {"type": ["string", "null"]},
    "economic_group_member_count": {"type": ["integer", "null"], "minimum": 1},
    "generated_at": {"type": "string", "format": "date-time"}
  }
}
