{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/rapporteur_change.schema.json",
  "title": "RapporteurChange",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "change_id",
    "process_id",
    "previous_rapporteur",
    "new_rapporteur",
    "decision_event_id",
    "post_change_decision_count",
    "red_flag",
    "generated_at"
