{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/procedural_timeline.schema.json",
  "title": "ProceduralTimeline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timeline_id",
    "process_id",
    "total_movement_count",
    "vista_count",
    "pauta_inclusion_count",
    "pauta_withdrawal_count",
    "pauta_cycle_count",
    "redistribution_count",
    "days_in_vista_total",
    "generated_at"
  ],
  "properties": {
    "timeline_id": {"type": "string"},
    "process_id": {"type": "string"},
    "process_number": {"type": ["string", "null"]},
    "process_class": {"type": ["string", "null"]},
    "first_distribution_date": {"type": ["string", "null"]},
    "first_decision_date": {"type": ["string", "null"]},
    "days_distribution_to_first_decision": {"type": ["integer", "null"]},
    "days_in_vista_total": {"type": "integer", "minimum": 0},
    "vista_count": {"type": "integer", "minimum": 0},
    "pauta_inclusion_count": {"type": "integer", "minimum": 0},
    "pauta_withdrawal_count": {"type": "integer", "minimum": 0},
    "pauta_cycle_count": {"type": "integer", "minimum": 0},
    "redistribution_count": {"type": "integer", "minimum": 0},
    "total_movement_count": {"type": "integer", "minimum": 0},
    "peer_group_key": {"type": ["string", "null"]},
    "peer_group_size": {"type": ["integer", "null"]},
    "peer_median_days_to_decision": {"type": ["number", "null"]},
    "peer_p5_days": {"type": ["number", "null"]},
    "peer_p95_days": {"type": ["number", "null"]},
    "vista_flag": {"type": "boolean"},
    "pauta_cycle_flag": {"type": "boolean"},
    "velocity_flag": {"type": ["string", "null"]},
    "generated_at": {"type": "string", "format": "date-time"}
  }
}
